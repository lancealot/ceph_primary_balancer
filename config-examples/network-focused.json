{
  "$schema": "https://docs.ceph.com/schemas/ceph-primary-balancer-config-v1.2.json",
  "description": "HOST+POOL optimization - network-focused strategy (~2.5× faster than Full 3D), prioritizes network balance over individual OSD balance",
  "optimization": {
    "target_cv": 0.10,
    "max_changes": null,
    "max_iterations": 10000,
    "enabled_levels": ["host", "pool"]
  },
  "scoring": {
    "weights": {
      "osd": 0.0,
      "host": 0.7,
      "pool": 0.3
    }
  },
  "output": {
    "directory": null,
    "json_export": true,
    "markdown_report": true,
    "script_name": "rebalance_primaries.sh"
  },
  "script": {
    "batch_size": 50,
    "health_check": true,
    "generate_rollback": true,
    "organized_by_pool": false
  },
  "verbosity": {
    "verbose": false,
    "quiet": false
  }
}
